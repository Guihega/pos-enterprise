# ============================================================
# POS Enterprise — Configuración de entorno
# ============================================================
# Este archivo es el TEMPLATE. Copiar a .env y ajustar valores.
# .env nunca se commitea (está en .gitignore).
# ============================================================

# --- Aplicación general ---
APP_NAME="POS Enterprise"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080
APP_TIMEZONE=America/Mexico_City
APP_LOCALE=es_MX
APP_FALLBACK_LOCALE=en

# --- Logging ---
LOG_CHANNEL=stack
LOG_LEVEL=debug
LOG_STACK=daily,stderr

# --- Base de datos (Postgres dentro de Docker) ---
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=pos
DB_USERNAME=pos
DB_PASSWORD=pos_dev_secret_change_me
DB_SCHEMA=public

# Connection pool (PgBouncer/Postgres direct en dev)
DB_POOL_MIN=2
DB_POOL_MAX=20

# --- Redis (cache, sessions, queues, broadcasting) ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=redis_dev_secret_change_me
REDIS_DB=0
REDIS_CACHE_DB=1
REDIS_QUEUE_DB=2
REDIS_SESSION_DB=3

# --- Sesiones, cache, queues, broadcasting ---
SESSION_DRIVER=redis
SESSION_LIFETIME=480          # 8 horas (en minutos)
SESSION_SECURE_COOKIE=false   # true en producción (HTTPS)
SESSION_SAME_SITE=lax

CACHE_DRIVER=redis
QUEUE_CONNECTION=redis
BROADCAST_DRIVER=reverb

# --- Reverb (WebSockets) ---
REVERB_APP_ID=pos-local
REVERB_APP_KEY=local_key_change_me
REVERB_APP_SECRET=local_secret_change_me
REVERB_HOST=reverb
REVERB_PORT=8080
REVERB_SCHEME=http

# --- Mail (MailHog en desarrollo) ---
MAIL_MAILER=smtp
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="no-reply@pos.local"
MAIL_FROM_NAME="${APP_NAME}"

# --- Storage ---
FILESYSTEM_DISK=local
# Para S3/Spaces en producción:
# FILESYSTEM_DISK=s3
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=
# AWS_BUCKET=
# AWS_ENDPOINT=                 # https://nyc3.digitaloceanspaces.com
# AWS_USE_PATH_STYLE_ENDPOINT=false

# --- Sanctum (auth) ---
SANCTUM_STATEFUL_DOMAINS=localhost:5173,localhost:8080,127.0.0.1:5173
SANCTUM_TOKEN_EXPIRATION=720   # 12 horas (minutos), absoluto

# --- Multi-tenant ---
TENANT_RESOLUTION=subdomain,header,jwt
TENANT_HEADER_NAME=X-Tenant
TENANT_FALLBACK_TO_DEFAULT=true   # solo en local; en prod siempre false

# --- Feature flags ---
FEATURE_OFFLINE_SYNC=true
FEATURE_FACTURACION_MX=false      # Se activa en Fase 4
FEATURE_LOYALTY=false             # Se activa en Fase 5
FEATURE_ECOMMERCE=false           # Se activa en Fase 9

# --- Frontend (Vite) ---
VITE_API_URL=http://localhost:8080/api/v1
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST=localhost
VITE_REVERB_PORT=8081
VITE_REVERB_SCHEME=ws

# --- Observabilidad (en desarrollo: opcional) ---
TELEMETRY_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318

# --- Integraciones externas (placeholders por fase) ---
# Fase 4 — Facturación MX
PAC_DRIVER=facturama
PAC_FACTURAMA_USER=
PAC_FACTURAMA_PASSWORD=
PAC_FACTURAMA_SANDBOX=true

# Fase 6 — Pasarelas de pago
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=

MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_PUBLIC_KEY=

# Fase 8 — Mensajería
WHATSAPP_PROVIDER=twilio
TWILIO_SID=
TWILIO_TOKEN=
TWILIO_FROM=

SENDGRID_API_KEY=

# --- Seguridad y operación ---
TRUSTED_PROXIES="*"               # Ajustar a IPs reales del LB en prod
RATE_LIMIT_API_PER_MINUTE=600
RATE_LIMIT_LOGIN_PER_MINUTE=5

# --- Modo demo ---
DEMO_MODE=false
DEMO_RESET_INTERVAL_HOURS=168     # 7 días
